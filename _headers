# ComprimeFotos Cache Headers for Cloudflare Pages
# UTF-8 no BOM
# https://developers.cloudflare.com/pages/platform/headers/
#
# KEY RULE: CF Pages _headers merges ALL matching paths' same-name headers.
# Setting ANY header on /* catch-all would merge with /, /tools/*, /blog/*, etc.
# Fix: /* catch-all must NOT set ANY header — let unmatched files use defaults.

# ── 404: no cache ──
/404.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# ── Homepage (clean URL root) ──
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=43200
  Content-Type: text/html; charset=utf-8

# ── Tool pages ──
/tools/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=43200
  Content-Type: text/html; charset=utf-8

# ── Blog pages ──
/blog/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=43200
  Content-Type: text/html; charset=utf-8

# ── City pages (ciudades) ──
/ciudades/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=43200
  Content-Type: text/html; charset=utf-8

# ── Clean URL pages ──
# CRITICAL: CF Pages _headers matches URL path, NOT internal file path.
# Users visit /about, NOT /about.html — /*.html rule does NOT match clean URLs!
/about
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=43200
  Content-Type: text/html; charset=utf-8
