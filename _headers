# ComprimeFotos Cache Headers for Cloudflare Pages
# UTF-8 no BOM
# https://developers.cloudflare.com/pages/platform/headers/
#
# KEY RULE: CF Pages _headers merges ALL matching paths' same-name headers.
# So / matches BOTH / AND /* — two values get comma-merged!
# Fix: catch-all /* must NOT set CDN-Cache-Control (to avoid merging with HTML rules).
#
# Strategy:
#   - HTML pages: CDN cache 1h, browser revalidate every time
#   - CSS/JS: CDN cache 7d, browser cache 7d
#   - Images: CDN cache 30d, browser cache 30d
#   - Sitemap/robots/feed: CDN cache 30min
#   - 404: no CDN cache (Negative Cache R0 handles 4xx)
#   - Fonts: CDN cache 1y, browser cache 1y

# ── 404: no cache ──
/404.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# ── Homepage (clean URL root) ──
/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8

# ── Tool pages ──
/tools/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8

# ── Blog pages ──
/blog/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8

# ── Clean URL pages (CRITICAL: CF Pages _headers matches URL path, NOT file path) ──
# Users visit /about, NOT /about.html — so /*.html rule does NOT match clean URLs!
# Each clean URL must have its own explicit rule.
/about
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/about.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/contact
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/contact.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/contacto
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/contacto.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/privacy
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/privacy.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/terms
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/terms.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/cookie-policy
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/cookie-policy.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
/descargo
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=3600
  Content-Type: text/html; charset=utf-8
