# ── Sitemap: CDN cache 30min ──
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800
  Content-Type: application/xml; charset=utf-8

# ── Robots.txt: CDN cache 30min ──
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800

# ── CSS: CDN cache 7d, browser 7d (match all subpaths) ──
/css/**
  Cache-Control: public, max-age=604800
  CDN-Cache-Control: public, max-age=604800

# ── JS: CDN cache 7d, browser 7d (match all subpaths) ──
/js/**
  Cache-Control: public, max-age=604800, immutable
  CDN-Cache-Control: public, max-age=604800

# ── Images directory: 30d (match all subpaths) ──
/images/**
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

# ── Image extensions ──
/*.png
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.jpg
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.jpeg
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.gif
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.svg
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

/*.ico
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

# ── favicon.svg: 1y ──
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# ── Fonts: 1y ──
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# ── Catch-all: NO headers ──
# Cannot set ANY header here — merges with all paths above, breaking cache logic.
# Files not matched by specific rules (ads.txt, google verification, etc.) use defaults.

