# Cabeceras personalizadas para Cloudflare Pages
# ⚠️ Regla de oro: NO usar /* como catch-all (CF Pages fusiona, no sobrescribe)

# ── HTML: navegador no-cache, CDN 2 horas ──
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=7200
  Content-Type: text/html; charset=utf-8

# ── URLs limpias (sin .html) ──
/tools/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=7200
  Content-Type: text/html; charset=utf-8

/blog/*
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=7200
  Content-Type: text/html; charset=utf-8

/
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=7200
  Content-Type: text/html; charset=utf-8

# ── Sitemap: no cache ──
/sitemap.xml
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-cache
  Content-Type: application/xml; charset=utf-8

# ── 404: no cache ──
/404.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-cache

# ── CSS: 1 año + immutable (?v=2 query busting) ──
/css/*
  Cache-Control: public, max-age=31536000, immutable

# ── JS: 1 año + immutable (?v=2 query busting) ──
/js/*
  Cache-Control: public, max-age=31536000, immutable

# ── Favicon ──
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

# ── Robots.txt: 1 día ──
/robots.txt
  Cache-Control: public, max-age=86400
