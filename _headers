# ── Sitemap: CDN cache 30min ──
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800
  Content-Type: application/xml; charset=utf-8

# ── Robots.txt: CDN cache 30min ──
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
  CDN-Cache-Control: public, max-age=1800

# ── CSS: CDN cache 7d, browser 7d ──
/css/*
  Cache-Control: public, max-age=604800
  CDN-Cache-Control: public, max-age=604800

# ── JS: CDN cache 7d, browser 7d ──
/js/*
  Cache-Control: public, max-age=604800, immutable
  CDN-Cache-Control: public, max-age=604800

# ── Images: CDN cache 30d ──
/images/*
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

# ── Individual image extensions ──
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.svg
/*.ico
  Cache-Control: public, max-age=2592000, immutable
  CDN-Cache-Control: public, max-age=2592000

# ── favicon.svg: 1y ──
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# ── Fonts: 1y ──
/*.woff
/*.woff2
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# ── Catch-all: browser cache 7d ONLY ──
# NO CDN-Cache-Control here! Otherwise it merges with / rules above.
/*
  Cache-Control: public, max-age=604800
